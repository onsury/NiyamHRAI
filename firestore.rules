rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === Helper Functions ===
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getTargetUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function sameOrgAsTarget(userId) {
      return isSignedIn() && getTargetUserData(userId).organizationId == getUserData().organizationId;
    }

    function isAdminInSameOrgAsTarget(userId) {
      return sameOrgAsTarget(userId) && (getUserData().role == 'FOUNDER' || getUserData().role == 'HR_ADMIN');
    }

    function belongsToOrg(orgId) {
      return isSignedIn() && getUserData().organizationId == orgId;
    }

    function isFounderOfOrg(orgId) {
      return isSignedIn() && getUserData().organizationId == orgId && getUserData().role == 'FOUNDER';
    }

    function isAdminOfOrg(orgId) {
      return isSignedIn() && getUserData().organizationId == orgId && (getUserData().role == 'FOUNDER' || getUserData().role == 'HR_ADMIN');
    }

    function isManagerOf(employeeUid) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(employeeUid)).data.managerId == request.auth.uid;
    }

    // === Users Collection ===
    match /users/{userId} {
      // Read: own profile, admin of same org, or manager of this user
      allow read: if isOwner(userId)
        || (isSignedIn() && isAdminOfOrg(resource.data.organizationId))
        || (isSignedIn() && resource.data.managerId == request.auth.uid);

      // Create: ONLY founders creating a fresh org (orgId == uid). 
      // All other profile creation must go through /api/invite/accept (server-side, bypasses rules).
      allow create: if isOwner(userId)
        && request.resource.data.role == 'FOUNDER'
        && request.resource.data.organizationId == userId
        && request.resource.data.onboarded == false;

      // Update: own profile, but CANNOT change role or organizationId
      // OR admin updating non-role fields on an org member
      allow update: if (isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'organizationId']))
        || (isSignedIn() && isAdminOfOrg(resource.data.organizationId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
        || (isSignedIn() && resource.data.managerId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['managerRating']));

      // Delete: own profile or admin
      allow delete: if isOwner(userId) || (isSignedIn() && isAdminOfOrg(resource.data.organizationId));

      // === Employee DNA ===
      match /employeeDNA/{docId} {
        allow read: if isOwner(userId)
          || isAdminInSameOrgAsTarget(userId)
          || (isSignedIn() && isManagerOf(userId));
        allow write: if isOwner(userId);
      }

      // === DNA History (Immutable) ===
      match /dnaHistory/{docId} {
        allow read: if isOwner(userId)
          || isAdminInSameOrgAsTarget(userId)
          || (isSignedIn() && isManagerOf(userId));
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // === Check-ins ===
      match /checkIns/{docId} {
        allow read: if isOwner(userId)
          || isAdminInSameOrgAsTarget(userId)
          || (isSignedIn() && isManagerOf(userId));
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // === Honing Sessions ===
      match /honingSessions/{docId} {
        allow read: if isOwner(userId)
          || isAdminInSameOrgAsTarget(userId)
          || (isSignedIn() && isManagerOf(userId));
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // === Reports ===
      match /reports/{docId} {
        allow read: if isOwner(userId)
          || isAdminInSameOrgAsTarget(userId)
          || (isSignedIn() && isManagerOf(userId));
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // === Rating History (server-written, immutable; read by owner, admins, manager) ===
      match /ratingHistory/{docId} {
        allow read: if isOwner(userId)
          || isAdminInSameOrgAsTarget(userId)
          || (isSignedIn() && isManagerOf(userId));
        allow write: if false;
      }
    }

    // === Organizations Collection ===
    match /organizations/{orgId} {
      allow read: if belongsToOrg(orgId);
      allow create: if isSignedIn() && request.auth.uid == orgId;
      allow update: if isAdminOfOrg(orgId);
      allow delete: if isFounderOfOrg(orgId);

      // Founder DNA
      match /founderDNA/{docId} {
        allow read: if belongsToOrg(orgId);
        allow write: if isFounderOfOrg(orgId);
      }

      // Competency Framework
      match /competencyFramework/{docId} {
        allow read: if belongsToOrg(orgId);
        allow write: if isAdminOfOrg(orgId);
      }

      // Org Analytics (server-only write)
      match /orgAnalytics/{docId} {
        allow read: if isAdminOfOrg(orgId);
        allow write: if false;
      }

      // Settings (white-label, billing)
      match /settings/{docId} {
        allow read: if belongsToOrg(orgId);
        allow write: if isFounderOfOrg(orgId);
      }
    }

    // === Invites (server-managed via Admin SDK; clients can only list their own sent invites) ===
    match /invites/{token} {
      // Admins can list invites for their org (used on the team page)
      allow read: if isSignedIn() && isAdminOfOrg(resource.data.organizationId);
      // Creation, acceptance, and deletion all go through the server (Admin SDK bypasses rules)
      allow write: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}