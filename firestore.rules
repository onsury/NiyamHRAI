rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === HELPER FUNCTIONS ===
    
    // Check if the requesting user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Check if the requesting user owns this document
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    // Get the requesting user's profile
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Check if user belongs to a specific org
    function belongsToOrg(orgId) {
      return isSignedIn() && getUserData().organizationId == orgId;
    }
    
    // Check if user is the founder of a specific org
    function isFounderOfOrg(orgId) {
      return isSignedIn() && belongsToOrg(orgId) && getUserData().role == 'FOUNDER';
    }
    
    // Check if user is HR Admin or Founder of a specific org
    function isAdminOfOrg(orgId) {
      return isSignedIn() && belongsToOrg(orgId) && (getUserData().role == 'FOUNDER' || getUserData().role == 'HR_ADMIN');
    }

    // =====================================================
    // USERS COLLECTION
    // =====================================================
    match /users/{userId} {
      // Users can read their own profile
      // Founders/HR can read profiles of users in their org
      allow read: if isOwner(userId) 
                  || isAdminOfOrg(resource.data.organizationId);
      
      // Users can create their own profile during signup
      allow create: if isOwner(userId);
      
      // Users can update their own profile
      // But CANNOT change their role or organizationId (admin-only fields)
      allow update: if isOwner(userId) 
                    && (!request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['role']));
      
      // Only the user themselves can delete their profile
      allow delete: if isOwner(userId);

      // --- Employee DNA subcollection ---
      match /employeeDNA/{docId} {
        // Employee can read/write their own DNA
        // Founder/HR can read employee DNA in their org
        allow read: if isOwner(userId) 
                    || isAdminOfOrg(getUserData().organizationId);
        allow write: if isOwner(userId);
      }

      // --- DNA History subcollection ---
      match /dnaHistory/{docId} {
        allow read: if isOwner(userId) 
                    || isAdminOfOrg(getUserData().organizationId);
        allow create: if isOwner(userId);
        allow update, delete: if false; // History is immutable
      }

      // --- Check-ins subcollection ---
      match /checkIns/{docId} {
        allow read: if isOwner(userId) 
                    || isAdminOfOrg(getUserData().organizationId);
        allow create: if isOwner(userId);
        allow update, delete: if false; // Check-ins are immutable
      }

      // --- Honing Sessions subcollection ---
      match /honingSessions/{docId} {
        allow read: if isOwner(userId) 
                    || isAdminOfOrg(getUserData().organizationId);
        allow create: if isOwner(userId);
        allow update, delete: if false; // Sessions are immutable
      }
    }

    // =====================================================
    // ORGANIZATIONS COLLECTION
    // =====================================================
    match /organizations/{orgId} {
      // Anyone in the org can read org details
      allow read: if belongsToOrg(orgId);
      
      // Only founder can create their org (during signup)
      allow create: if isSignedIn() && request.auth.uid == orgId;
      
      // Only founder/HR can update org details
      allow update: if isAdminOfOrg(orgId);
      
      // Only founder can delete org
      allow delete: if isFounderOfOrg(orgId);

      // --- Founder DNA subcollection ---
      match /founderDNA/{docId} {
        // Anyone in the org can read founder DNA (it's the benchmark)
        allow read: if belongsToOrg(orgId);
        
        // Only the founder can write their DNA
        allow write: if isFounderOfOrg(orgId);
      }

      // --- Competency Framework subcollection ---
      match /competencyFramework/{docId} {
        // Anyone in the org can read the framework
        allow read: if belongsToOrg(orgId);
        
        // Only founder/HR can modify the framework
        allow write: if isAdminOfOrg(orgId);
      }
    }

    // =====================================================
    // CATCH-ALL: Deny everything else
    // =====================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
