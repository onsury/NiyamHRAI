rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === Helper Functions ===
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function belongsToOrg(orgId) {
      return isSignedIn() && getUserData().organizationId == orgId;
    }

    function isFounderOfOrg(orgId) {
      return isSignedIn() && getUserData().organizationId == orgId && getUserData().role == 'FOUNDER';
    }

    function isAdminOfOrg(orgId) {
      return isSignedIn() && getUserData().organizationId == orgId && (getUserData().role == 'FOUNDER' || getUserData().role == 'HR_ADMIN');
    }

    // === Users Collection ===
    match /users/{userId} {
      // Read: own profile OR admin of their org
      allow read: if isOwner(userId) || (isSignedIn() && isAdminOfOrg(resource.data.organizationId));

      // Create: only during signup (own UID)
      allow create: if isOwner(userId);

      // Update: own profile, but CANNOT change role
      allow update: if isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));

      // Delete: own profile only
      allow delete: if isOwner(userId);

      // === Employee DNA ===
      match /employeeDNA/{docId} {
        allow read: if isOwner(userId) || isAdminOfOrg(resource.data.organizationId || 'none');
        allow write: if isOwner(userId);
      }

      // === DNA History (Immutable — no updates/deletes) ===
      match /dnaHistory/{docId} {
        allow read: if isOwner(userId) || isAdminOfOrg(getUserData().organizationId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // === Check-ins ===
      match /checkIns/{docId} {
        allow read: if isOwner(userId) || isAdminOfOrg(getUserData().organizationId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // === Honing Sessions ===
      match /honingSessions/{docId} {
        allow read: if isOwner(userId) || isAdminOfOrg(getUserData().organizationId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // === Reports ===
      match /reports/{docId} {
        allow read: if isOwner(userId) || isAdminOfOrg(getUserData().organizationId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }

    // === Organizations Collection ===
    match /organizations/{orgId} {
      allow read: if belongsToOrg(orgId);
      allow create: if isSignedIn() && request.auth.uid == orgId;
      allow update: if isAdminOfOrg(orgId);
      allow delete: if isFounderOfOrg(orgId);

      // Founder DNA
      match /founderDNA/{docId} {
        allow read: if belongsToOrg(orgId);
        allow write: if isFounderOfOrg(orgId);
      }

      // Competency Framework
      match /competencyFramework/{docId} {
        allow read: if belongsToOrg(orgId);
        allow write: if isAdminOfOrg(orgId);
      }

      // Org Analytics
      match /orgAnalytics/{docId} {
        allow read: if isAdminOfOrg(orgId);
        allow write: if false; // server-only
      }

      // Settings (White-label, billing)
      match /settings/{docId} {
        allow read: if belongsToOrg(orgId);
        allow write: if isFounderOfOrg(orgId);
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
